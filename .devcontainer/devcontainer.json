{
  "name": "Claude Code",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },
    "ghcr.io/shyim/devcontainers-features/bun:0": {
      "version": "1.3.5"
    }
  },
  "postCreateCommand": "bun install",
  "customizations": {
    "vscode": {
      "extensions": [
        "oven.bun-vscode"
      ],
      "settings": {
        "search.exclude": {
          "**/node_modules": true,
          "**/dist": true,
          "**/build": true
        }
      }
    }
  }
}
